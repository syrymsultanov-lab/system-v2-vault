# ============================================================
# Content Factory — SYSTEM-v3.0
# Скопируйте этот файл в .env и заполните своими значениями
# НИКОГДА не коммитьте .env в git!
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://njwraxmlzglmofxiwmxs.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
# Где взять: Supabase Dashboard → Settings → API → service_role key

# --- Claude API (Anthropic) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Где взять: https://console.anthropic.com → API Keys

# --- YouTube Data API v3 ---
YOUTUBE_API_KEY=your_youtube_data_api_key_here
# Где взять: console.cloud.google.com → APIs → YouTube Data API v3

# --- YouTube OAuth 2.0 (для публикации Community Posts) ---
YOUTUBE_CLIENT_ID=your_oauth_client_id
YOUTUBE_CLIENT_SECRET=your_oauth_client_secret
YOUTUBE_REFRESH_TOKEN=your_refresh_token
# Где взять: console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
# Инструкция: docs/API_KEYS.md → раздел YouTube OAuth

# --- Instagram Graph API ---
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
# Где взять: developers.facebook.com → My Apps → Instagram Basic Display
# Инструкция: docs/API_KEYS.md → раздел Instagram

# --- Leonardo AI (для генерации изображений) ---
LEONARDO_API_KEY=your_leonardo_api_key
# Где взять: app.leonardo.ai → Settings → API

# --- Telegram (для уведомлений об ошибках) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_personal_chat_id
# Где взять: @BotFather в Telegram → /newbot

# --- n8n ---
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.hostinger.com
N8N_API_KEY=your_n8n_api_key
