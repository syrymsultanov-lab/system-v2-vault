        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {entity_type: 'workflow', event: 'wf13_stuck_jobs_reset', actor: 'system', payload: {reset_count: Number($('10_Reset_Stuck_Jobs').item.json.body) || 0, threshold_minutes: 10, run_at: new Date().toISOString()}} }}"
