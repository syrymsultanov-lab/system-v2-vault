      "id": "6a09af7c-362c-4409-9a8e-a2c33befddcc",
      "name": "01_Schedule_Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        -1080,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.SUPABASE_URL + '/rest/v1/rpc/claim_next_ai_job'}}",
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$env.SUPABASE_SERVICE_ROLE_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "={{'Bearer ' + $env.SUPABASE_SERVICE_ROLE_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {p_job_type: 'qualify_lead'} }}"
      },
      "id": "eec394cb-757e-44bb-bb83-1a61701c9560",
      "name": "10_Claim_Job",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -860,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const job = $json.body;\nif (!job || typeof job !== 'object' || !job.id) {\n  return [];\n}\nreturn [job];"
      },
      "id": "f0be18b4-0684-48a8-9232-81fd29239cb7",
      "name": "11_Process_Claim",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -640,
        0
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.SUPABASE_URL + '/rest/v1/leads?select=*&id=eq.' + $('11_Process_Claim').item.json.target_id + '&limit=1'}}",
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$env.SUPABASE_SERVICE_ROLE_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "={{'Bearer ' + $env.SUPABASE_SERVICE_ROLE_KEY}}"
            }
          ]
        }
      },
      "id": "0e1554a9-7910-49c4-8cd2-f9c7df8511f3",
      "name": "20_Fetch_Lead",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -420,
        0
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const body = $json.body;\nconst lead = Array.isArray(body) ? body[0] : (body && body[0]);\nif (!lead) {\n  throw new Error('Lead not found for target_id=' + $('11_Process_Claim').item.json.target_id);\n}\nconst prompt = `Ты AI qualifier SYSTEM V2. Верни JSON с keys: score (0-100 int), temperature (hot|warm|cold), next_action (string), summary (string). Lead: ${JSON.stringify(lead)}`;\nreturn [{ job_id: $('11_Process_Claim').item.json.id, lead_id: lead.id, partner_id: lead.partner_id, prompt }];"
      },
      "id": "a9ab72fa-53ee-46ec-b41d-71c885eb6157",
      "name": "30_Build_Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -200,
        0
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.OPENAI_BASE_URL || 'https://api.openai.com/v1/chat/completions'}}",
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "={{'Bearer ' + $env.OPENAI_API_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {model: $env.OPENAI_MODEL || 'gpt-4.1-mini', response_format:{type:'json_object'}, messages:[{role:'system', content:'Return only valid JSON.'},{role:'user', content:$json.prompt}] } }}"
      },
      "id": "98a77da3-9458-4e42-9d07-27ef4e1b2069",
      "name": "40_OpenAI_Qualification",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        20,
        0
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const raw = $json.body?.choices?.[0]?.message?.content;\nif (!raw) {\n  throw new Error('OpenAI returned empty content');\n}\nlet parsed;\ntry {\n  parsed = JSON.parse(raw);\n} catch (e) {\n  throw new Error('OpenAI JSON parse failed: ' + e.message + ' | raw=' + String(raw).slice(0, 500));\n}\nreturn [{\n  job_id: $('30_Build_Prompt').item.json.job_id,\n  lead_id: $('30_Build_Prompt').item.json.lead_id,\n  partner_id: $('30_Build_Prompt').item.json.partner_id,\n  score: parsed.score,\n  temperature: parsed.temperature,\n  next_action: parsed.next_action,\n  summary: parsed.summary,\n  raw\n}];"
      },
      "id": "1231900b-ad9d-4779-b5c6-4ede3feedd17",
      "name": "50_Parse_AI_JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        260,
        0
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{$env.SUPABASE_URL + '/rest/v1/leads?id=eq.' + $json.lead_id}}",
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$env.SUPABASE_SERVICE_ROLE_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "={{'Bearer ' + $env.SUPABASE_SERVICE_ROLE_KEY}}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {score: $json.score, status: 'qualified'} }}"
      },
      "id": "8b6e46b2-f694-4f83-967c-4ea2c13c3391",
      "name": "60_Update_Lead",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        500,
        0
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.SUPABASE_URL + '/rest/v1/ai_recommendations'}}",
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$env.SUPABASE_SERVICE_ROLE_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "={{'Bearer ' + $env.SUPABASE_SERVICE_ROLE_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"partner_id\": {{ JSON.stringify($('50_Parse_AI_JSON').item.json.partner_id || null) }},\n  \"target_type\": \"lead\",\n  \"target_id\": {{ JSON.stringify($('50_Parse_AI_JSON').item.json.lead_id) }},\n  \"recommendation_type\": \"qualification\",\n  \"recommendation_payload\": {\n    \"score\": {{ Number($('50_Parse_AI_JSON').item.json.score) || 0 }},\n    \"temperature\": {{ JSON.stringify($('50_Parse_AI_JSON').item.json.temperature || '') }},\n    \"next_action\": {{ JSON.stringify($('50_Parse_AI_JSON').item.json.next_action || '') }},\n    \"summary\": {{ JSON.stringify($('50_Parse_AI_JSON').item.json.summary || '') }}\n  },\n  \"confidence\": {{ (Number($('50_Parse_AI_JSON').item.json.score) || 0) / 100 }}\n}"
      },
      "id": "c5d18e7a-4b21-4f9a-8c3e-2a6f1b9d3e57",
      "name": "65_Insert_Recommendation",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        620,
