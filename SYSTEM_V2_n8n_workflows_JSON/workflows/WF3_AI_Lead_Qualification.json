        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"status\": \"succeeded\",\n  \"result\": {\n    \"score\": {{ Number($('50_Parse_AI_JSON').item.json.score) || 0 }},\n    \"temperature\": {{ JSON.stringify($('50_Parse_AI_JSON').item.json.temperature || '') }},\n    \"next_action\": {{ JSON.stringify($('50_Parse_AI_JSON').item.json.next_action || '') }},\n    \"summary\": {{ JSON.stringify($('50_Parse_AI_JSON').item.json.summary || '') }},\n    \"raw\": {{ JSON.stringify($('50_Parse_AI_JSON').item.json.raw || '') }}\n  }\n}"
      },
