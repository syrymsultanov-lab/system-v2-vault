        "jsonBody": "={\n  \"status\": \"failed\",\n  \"result\": {\n    \"error\": {{ JSON.stringify(($json.error && ($json.error.message || $json.error.description)) || (typeof $json.error === 'string' ? $json.error : 'unknown_error')) }},\n    \"failed_at\": {{ JSON.stringify(new Date().toISOString()) }}\n  }\n}"
      },
